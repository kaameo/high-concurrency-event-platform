  "panels": [
    {
      "title": "Application Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "up{job=\"spring-boot\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        },
        "overrides": []
      }
    },
    {
      "title": "HTTP Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-boot\", status=~\"2..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"spring-boot\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 0.99, "color": "yellow" }, { "value": 0.999, "color": "green" }] } }, "overrides": [] }
    },
    {
      "title": "HTTP p95 Latency",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"spring-boot\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.1, "color": "yellow" }, { "value": 0.2, "color": "red" }] } }, "overrides": [] }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus" },
      "targets": [
        { "expr": "system_cpu_usage{job=\"spring-boot\"}", "legendFormat": "System CPU", "refId": "A" },
        { "expr": "process_cpu_usage{job=\"spring-boot\"}", "legendFormat": "Process CPU", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] }
    },
    {
      "title": "JVM Heap Memory",
